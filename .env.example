DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sub_based_internet
REDIS_URL=redis://localhost:6379
API_PORT=3001
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
GATEWAY_API_URL=http://localhost:3001
GATEWAY_KEY=dev-gateway-key-downtown
GATEWAY_DRIVER=mock
GATEWAY_POLL_MS=30000
GATEWAY_USAGE_MS=300000
GATEWAY_FIRMWARE=1.0.0
# Rate limits (redeem + auth)
REDEEM_RATE_LIMIT=20
REDEEM_RATE_WINDOW_SEC=60
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW_SEC=60

# Set to 1 in production to block POST /auth/register
# DISABLE_PUBLIC_REGISTER=1

# Email (password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# SMS OTP (captive portal)
SMS_PROVIDER_URL=
SMS_API_KEY=
SMS_OTP_TTL_SEC=300
SMS_SESSION_MINS=30
SMS_SESSION_SPEED_MBPS=5

# Nepal payments (eSewa / Khalti)
ESEWA_MERCHANT_ID=
ESEWA_SECRET_KEY=
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_API_URL=https://rc-epay.esewa.com.np
KHALTI_SECRET_KEY=
KHALTI_API_URL=https://khalti.com/api/v2

# Stripe (optional — enables billing checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
# OpenWRT gateway (when GATEWAY_DRIVER=openwrt)
GATEWAY_LAN_DEV=br-lan
GATEWAY_FAIL_FAST=0
# MikroTik gateway (when GATEWAY_DRIVER=mikrotik)
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=admin
MIKROTIK_PASS=
MIKROTIK_SSH_PORT=22
