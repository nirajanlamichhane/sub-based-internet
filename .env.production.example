# Production environment — copy to .env and fill secrets
# Used with: docker compose -f docker-compose.prod.yml up --build

# Database (internal Docker network)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sub_based_internet
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/sub_based_internet

# Redis
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-me-jwt-secret
JWT_REFRESH_SECRET=change-me-jwt-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Public URLs (adjust for your domain)
WEB_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://your-domain.com
HTTP_PORT=80
HTTPS_PORT=443

# Auth hardening
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW_SEC=60
DISABLE_PUBLIC_REGISTER=1

# Stripe — see output/architecture/stripe-live-setup.md
# Create products/prices in Stripe Dashboard, then paste price IDs here
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Rate limits
REDEEM_RATE_LIMIT=20
REDEEM_RATE_WINDOW_SEC=60
