{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@sub-based-internet/shared": ["../../packages/shared/dist"],
      "@sub-based-internet/shared/*": ["../../packages/shared/dist/*"],
      "@sub-based-internet/db": ["../../packages/db/dist"]
    }
  },
  "include": ["src/**/*"]
}
