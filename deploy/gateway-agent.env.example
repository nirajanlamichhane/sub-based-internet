# Gateway agent environment — copy to /etc/wifi-saas/gateway.env on venue hardware
# chmod 600 /etc/wifi-saas/gateway.env

# Cloud API (production domain — nginx proxies /gateway/* to API)
GATEWAY_API_URL=https://your-domain.com

# From owner dashboard → Devices → location gateway key
GATEWAY_KEY=your-location-gateway-key

# Production enforcement
GATEWAY_DRIVER=openwrt
GATEWAY_LAN_DEV=br-lan
GATEWAY_FAIL_FAST=1

# Polling intervals
GATEWAY_POLL_MS=30000
GATEWAY_USAGE_MS=300000
GATEWAY_FIRMWARE=openwrt-pilot-1.0.0

# Optional
# GATEWAY_STATE_DIR=/tmp/wifi-saas
# GATEWAY_OFFLINE_GRACE_MS=3600000
