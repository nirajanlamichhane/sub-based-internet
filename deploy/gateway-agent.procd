#!/bin/sh /etc/rc.common
# OpenWRT procd init for Wi-Fi SaaS gateway agent
# Install: cp deploy/gateway-agent.procd /etc/init.d/wifi-saas-gateway

START=99
STOP=10
USE_PROCD=1

AGENT_DIR="/opt/wifi-saas"
ENV_FILE="/etc/wifi-saas/gateway.env"

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/node "${AGENT_DIR}/dist/index.js"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param env $(grep -v '^#' "$ENV_FILE" | xargs)
    procd_close_instance
}

stop_service() {
    return 0
}
